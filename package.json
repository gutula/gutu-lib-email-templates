{
  "name": "gutu-lib-email-templates",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/email-templates build",
    "typecheck": "bun run --cwd framework/libraries/email-templates typecheck",
    "lint": "bun run --cwd framework/libraries/email-templates lint",
    "test": "bun run --cwd framework/libraries/email-templates test",
    "test:unit": "bun run --cwd framework/libraries/email-templates test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
